# URI de conexión a MongoDB (local o Atlas)
MONGODB_URI=mongodb://localhost:27017

# Nombre de la base de datos
DATABASE_NAME=jht_chat

# Clave secreta para firmar tokens JWT (cambiar por un valor seguro en producción)
SECRET_KEY=cambia_esta_clave_por_una_muy_segura

# Algoritmo de firma JWT
ALGORITHM=HS256

# Tiempo de expiración del token JWT en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (cache de sesiones y presencia)
REDIS_URL=redis://localhost:6379

# RabbitMQ (cola de mensajes de chat)
RABBITMQ_URL=amqp://guest:guest@localhost/
