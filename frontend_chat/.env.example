# URI de conexión a MongoDB
# Nota: dentro de Docker se sobreescribe automáticamente a mongodb://mongodb:27017
MONGODB_URI=mongodb://mongodb:27017

# Nombre de la base de datos
DATABASE_NAME=jht_chat

# Clave secreta para firmar tokens JWT
SECRET_KEY=clave_super_secreta_cambiala_en_produccion_1234567890

# Algoritmo de firma JWT
ALGORITHM=HS256

# Tiempo de expiración del token en minutos (1440 = 24 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Orígenes permitidos para CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis
# Nota: dentro de Docker se sobreescribe automáticamente a redis://redis:6379
REDIS_URL=redis://redis:6379

# RabbitMQ
# Nota: dentro de Docker se sobreescribe automáticamente
RABBITMQ_URL=amqp://guest:guest@rabbitmq/

# Twilio (desactivado - dejar vacío para usar registro sin OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
